# ═══════════════════════════════════════════════════════════════════════════════
# Agency Management System - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# AI Provider API Keys (at least one required)
# ═══════════════════════════════════════════════════════════════════════════════

# OpenAI (Recommended for best performance)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq (Fast inference)
GROQ_API_KEY=your_groq_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL (optional - uses SQLite if not provided)
DATABASE_URL=postgresql://user:password@localhost/agency

# Redis (optional - for caching and queues)
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════════════════

# JWT Secret for API authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin API key for administrative operations
ADMIN_API_KEY=admin_key_change_this

# ═══════════════════════════════════════════════════════════════════════════════
# Monitoring & Observability
# ═══════════════════════════════════════════════════════════════════════════════

# OpenTelemetry endpoint (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Prometheus metrics port
METRICS_PORT=9090

# ═══════════════════════════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════════════════════════

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API server port
API_PORT=8000

# Frontend development server port
FRONTEND_PORT=3000

# ═══════════════════════════════════════════════════════════════════════════════
# Autonomous Mode Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# Default scan interval in seconds
DEFAULT_SCAN_INTERVAL=60

# Default scaling threshold (queue depth)
DEFAULT_SCALING_THRESHOLD=500

# Enable/disable autonomous mode by default
AUTONOMOUS_MODE_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# Integrations
# ═══════════════════════════════════════════════════════════════════════════════

# Slack webhook for notifications (optional)
SLACK_WEBHOOK_URL=

# Discord webhook for notifications (optional)
DISCORD_WEBHOOK_URL=

# Email SMTP settings for notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
